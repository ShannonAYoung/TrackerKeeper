{
  "name": "TrackerKeeperApp",
  "version": "1.0.0",
  "private": true,
  "type": "module",

  "scripts": {
    // React Native (correct usage of npx)
    "start": "npx react-native start",
    "android": "npx react-native run-android",
    "ios": "npx react-native run-ios",

    "build:ts": "npx tsc -p tsconfig.json",
    "start:ts": "npx ts-node src/server.ts",


    // Web (Vite)
    "dev:web": "vite",
    "build:web": "vite build",
    "preview:web": "vite preview",

    // Node TypeScript server
    "start:server": "npx ts-node src/server.ts",
    "build:server": "tsc -p tsconfig.json",

    // Testing + linting
    "test": "jest",
    "lint": "eslint .",

    // React Native bundle build
    "build": "react-native bundle --platform android --dev false --entry-file src/main.tsx --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/"
  },

  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.6",
    "expo": "50.0.0",

    "clsx": "^2.0.0",
    "lucide-react": "^0.263.1",
    "tailwind-merge": "^1.14.0",

    // TypeScript runtime tools
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },

  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",

    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/react-native": "^0.72.0",

    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",

    "metro-react-native-babel-preset": "^0.76.0",
    "@react-native/metro-config": "^0.76.0",

    "react-test-renderer": "18.2.0",

    // Vite + React
    "@vitejs/plugin-react": "^5.1.3",
    "vite": "^7.3.1",

    // Optional: path alias support
    "tsconfig-paths": "^4.2.0"
  },

  "jest": {
    "preset": "react-native"
  }
}